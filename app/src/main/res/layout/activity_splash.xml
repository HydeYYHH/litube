<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/splash_bg">

    <!-- Subtle Depth Glow -->
    <View
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:background="@drawable/splash_glow"
        app:layout_constraintBottom_toBottomOf="@+id/logo"
        app:layout_constraintEnd_toEndOf="@+id/logo"
        app:layout_constraintStart_toStartOf="@+id/logo"
        app:layout_constraintTop_toTopOf="@+id/logo" />

    <ImageView
        android:id="@+id/logo"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:contentDescription="@null"
        android:src="@mipmap/ic_launcher"
        app:layout_constraintBottom_toTopOf="@+id/app_name"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.45"
        app:layout_constraintVertical_chainStyle="packed" />

    <TextView
        android:id="@+id/app_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:fontFamily="sans-serif-black"
        android:letterSpacing="0.04"
        android:text="@string/app_name"
        android:textColor="@color/splash_text"
        android:textSize="30sp"
        app:layout_constraintBottom_toTopOf="@+id/tagline_container"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/logo" />

    <LinearLayout
        android:id="@+id/tagline_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/app_name">

        <TextView
            android:id="@+id/tagline_fast"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:alpha="0"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.30"
            android:text="Fast"
            android:textAllCaps="true"
            android:textColor="@color/splash_secondary_text"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tagline_dot1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:alpha="0"
            android:paddingHorizontal="6dp"
            android:text="•"
            android:textColor="@color/splash_secondary_text"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tagline_minimal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:alpha="0"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.30"
            android:text="Minimal"
            android:textAllCaps="true"
            android:textColor="@color/splash_secondary_text"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tagline_dot2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:alpha="0"
            android:paddingHorizontal="6dp"
            android:text="•"
            android:textColor="@color/splash_secondary_text"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tagline_simple"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:alpha="0"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.30"
            android:text="Simple"
            android:textAllCaps="true"
            android:textColor="@color/splash_secondary_text"
            android:textSize="13sp" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="40dp"
        android:fontFamily="sans-serif-light"
        android:text="Premium Experience"
        android:textColor="@color/splash_secondary_text"
        android:textSize="11sp"
        android:textAllCaps="true"
        android:letterSpacing="0.1"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>